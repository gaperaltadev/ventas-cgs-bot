# ─── Supabase ────────────────────────────────────────────────────────────────
# El cliente de Supabase lo usan tanto el worker como los handlers.
# La service key tiene acceso completo — no usar la anon key acá.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Worker de cola ──────────────────────────────────────────────────────────
# Intervalo de polling de bot_queue en milisegundos (default: 2000 = 2 seg).
# Bajar a 1000 para mayor velocidad de respuesta; subir para reducir carga.
WORKER_INTERVAL_MS=2000

# ─── Comportamiento del bot ──────────────────────────────────────────────────
# Prefijo que activa los comandos del bot en los mensajes de WhatsApp.
BOT_PREFIX=/

# Allowlist de fallback. La fuente principal es la tabla `vendedores`
# en Supabase (refrescada en caché cada 5 min). Esta variable se usa
# solo si la tabla está vacía o inaccesible (modo dev local).
ALLOWED_NUMBERS=

# ─── Puerto del servidor HTTP ────────────────────────────────────────────────
# En Railway lo asigna automáticamente vía $PORT.
PORT=3000

# ─── Sentry (opcional) ───────────────────────────────────────────────────────
# Si está configurado, los errores se reportan a Sentry.
SENTRY_DSN=

# ─── Meta WhatsApp Cloud API ─────────────────────────────────────────────────
# Usadas por el worker para enviar mensajes salientes a WhatsApp.

# ID del número de WhatsApp Business (panel de Meta for Developers)
META_PHONE_NUMBER_ID=

# Token de acceso permanente de Meta para enviar mensajes
META_ACCESS_TOKEN=

# ─── Referencia: variables que usa n8n (no este backend) ─────────────────────
# n8n necesita la SUPABASE_SERVICE_KEY para insertar en bot_queue.
# n8n necesita META_VERIFY_TOKEN para verificar el webhook de Meta.
# Configurarlas directamente en el environment de n8n — no acá.
#
# META_VERIFY_TOKEN=   (solo n8n)
