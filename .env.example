# ─── Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ─── Comportamiento del bot ──────────────────────────────────────────────
# Prefijo que activa los comandos del bot (en mensajes de WhatsApp)
BOT_PREFIX=/

# Allowlist de fallback. La fuente principal es la tabla `vendedores`
# en Supabase (refrescada en cache cada 5 min). Esta variable se usa
# solo si la tabla está vacía o inaccesible (modo dev local).
ALLOWED_NUMBERS=

# Puerto del servidor HTTP. En Railway lo asigna automáticamente.
PORT=3000

# ─── Integración con n8n ─────────────────────────────────────────────────
# Secreto compartido entre n8n y el backend. n8n lo envía en el header
# X-N8N-SECRET para autenticar las llamadas a POST /webhook.
N8N_SHARED_SECRET=

# ─── Meta WhatsApp Cloud API ─────────────────────────────────────────────
# Estas variables las usa n8n (no el backend) para validar el webhook
# de Meta y para enviar mensajes salientes. Se documentan acá como
# referencia centralizada.

# Token que Meta envía en la verificación inicial del webhook
META_VERIFY_TOKEN=

# ID del número de WhatsApp Business asociado (después de verificación)
META_PHONE_NUMBER_ID=

# Token de acceso permanente de Meta para enviar mensajes
META_ACCESS_TOKEN=
