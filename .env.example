SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Números autorizados (formato internacional sin +, separados por coma)
ALLOWED_NUMBERS=595981234567,595987654321

# Prefijo para activar el bot
BOT_PREFIX=/

# Solo para primer auth en servidor (Railway). Después puede dejarse o sacarse.
# Formato: sin +, sin espacios. Ej: 595981234567
PHONE_NUMBER=

# Token de acceso al servidor web de vinculación (página con QR + pairing code).
# Si lo dejás vacío, se genera uno random en cada arranque y se imprime en logs.
# Recomendado: poner uno fijo así no cambia al reiniciar.
AUTH_SERVER_TOKEN=

# Puerto del servidor web. En Railway se asigna automáticamente vía $PORT.
PORT=3000

# Pausa de emergencia: si la ponés en true, el bot NO se conecta a WhatsApp
# (útil durante un ban para detener intentos sin tocar Railway).
# La página web sigue funcionando y muestra el estado de pausa.
# Para reactivar: quitala o ponela en cualquier otro valor + redeploy.
BOT_PAUSED=
